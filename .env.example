# LLM (default: Groq)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Vector store
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=shopsmart_support

# --- Security (recommended for any public deployment) ---
# Streamlit: if set, KB load / uploads / URL ingest / reset require this password.
ADMIN_PASSWORD=

# If false, Streamlit hides all document admin controls (chat-only UI).
ENABLE_PUBLIC_ADMIN=true

# FastAPI: if set, Bearer token required for /status, /ingest/*, DELETE /collection.
API_TOKEN=

# Comma-separated CORS origins; leave empty for allow-all (local dev only).
ALLOWED_ORIGINS=

# Upload / URL fetch limits
MAX_UPLOAD_BYTES=20971520
MAX_URL_FETCH_BYTES=10485760
MAX_URL_REDIRECTS=5
URL_FETCH_TIMEOUT_SECONDS=30

# Optional: comma-separated hostnames allowed for URL ingestion (empty = no host allowlist).
URL_ALLOWLIST=
